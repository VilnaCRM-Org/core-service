{
  "name": "vilnacrm/core-service",
  "description": "Microservices template for modern PHP applications",
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-iconv": "*",
    "ext-mbstring": "*",
    "ext-mongodb": "^2.1",
    "ext-simplexml": "*",
    "ext-xml": "*",
    "api-platform/core": "4.3.*",
    "aws/aws-sdk-php": "^3.317.1",
    "cfpinto/graphql": "^2.0",
    "doctrine/mongodb-odm": "^2.10",
    "doctrine/mongodb-odm-bundle": "^5.3",
    "dpauli/graphql-request-builder": "^1.8",
    "phpmailer/phpmailer": "^7.0",
    "symfony/asset": "8.0.*",
    "symfony/cache": "7.4.*",
    "symfony/console": "7.4.*",
    "symfony/dotenv": "8.0.*",
    "symfony/flex": "^2.2",
    "symfony/framework-bundle": "7.4.*",
    "symfony/http-foundation": "^7.4",
    "symfony/messenger": "8.0.*",
    "symfony/proxy-manager-bridge": "^6.4",
    "symfony/runtime": "8.0.*",
    "symfony/translation": "7.4.*",
    "symfony/twig-bundle": "7.4.*",
    "symfony/uid": "8.0.*",
    "symfony/validator": "7.4.*",
    "symfony/yaml": "7.4.*",
    "webonyx/graphql-php": "^15.14",
    "mongodb/mongodb": "~2.2.0"
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "symfony/flex": true,
      "symfony/runtime": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": false
    },
    "optimize-autoloader": true,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "platform": {
      "php": "8.4.3",
      "ext-mongodb": "2.1.8"
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "7.4.*",
      "docker": true
    },
    "_comments": {
      "behat-gherkin": "Compatibility issue from Behat/Gherkin issue #317 is resolved; the project now uses 4.16.1."
    }
  },
  "require-dev": {
    "behat/behat": "^3.19",
    "behat/gherkin": "4.16.1",
    "behat/mink": "^1.12",
    "behat/mink-browserkit-driver": "^2.0",
    "dg/bypass-finals": "^1.5",
    "doctrine/data-fixtures": "^2.0",
    "fakerphp/faker": "^1.23.0",
    "friends-of-behat/symfony-extension": "^2.4",
    "friendsofphp/php-cs-fixer": "^3.14",
    "infection/infection": "^0.32.3",
    "marcocesarato/php-conventional-changelog": "^1.16",
    "nunomaduro/phpinsights": "^2.7",
    "pheromone/phpcs-security-audit": "^2.0",
    "phpmd/phpmd": "^2.15",
    "phpmetrics/phpmetrics": "^2.9",
    "phpunit/phpunit": "^10.5",
    "psalm/plugin-phpunit": "^0.19.5",
    "psalm/plugin-symfony": "^5.2.8",
    "qossmic/deptrac-shim": "^1.0",
    "ramsey/conventional-commits": "^1.6",
    "shipmonk/memory-scanner": "^1.0",
    "symfony/browser-kit": "8.0.*",
    "symfony/css-selector": "8.0.*",
    "symfony/mime": "^8.0",
    "symfony/phpunit-bridge": "8.0.*",
    "twentytwo-labs/behat-open-api": "^1.0",
    "vimeo/psalm": "^6.15",
    "weirdan/doctrine-psalm-plugin": "^2.10"
  },
  "version": "0.9.0"
}
