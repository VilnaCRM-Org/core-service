{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "task",
    "bundle_id",
    "bundle_dir",
    "artifacts",
    "validation_rounds",
    "open_questions",
    "warnings",
    "github"
  ],
  "properties": {
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "complete",
        "complete-with-warnings",
        "failed"
      ]
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_dir": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "research",
        "brief",
        "distillate",
        "prd",
        "architecture",
        "epics",
        "implementation_readiness",
        "run_summary"
      ],
      "properties": {
        "research": {
          "type": "string",
          "minLength": 1
        },
        "brief": {
          "type": "string",
          "minLength": 1
        },
        "distillate": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "prd": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "string",
          "minLength": 1
        },
        "epics": {
          "type": "string",
          "minLength": 1
        },
        "implementation_readiness": {
          "type": "string",
          "minLength": 1
        },
        "run_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation_rounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "research",
        "brief",
        "prd",
        "architecture",
        "epics",
        "stories"
      ],
      "properties": {
        "research": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "brief": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "prd": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "architecture": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "epics": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "stories": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_status",
        "issue_number",
        "issue_url",
        "pr_status",
        "pr_number",
        "pr_url",
        "branch",
        "error"
      ],
      "properties": {
        "issue_status": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "skipped",
            "created",
            "failed"
          ]
        },
        "issue_number": {
          "type": [
            "integer",
            "null"
          ]
        },
        "issue_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "pr_status": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "skipped",
            "created",
            "failed"
          ]
        },
        "pr_number": {
          "type": [
            "integer",
            "null"
          ]
        },
        "pr_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "branch": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "error": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
