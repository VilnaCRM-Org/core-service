<doctrine-mongo-mapping
  xmlns="http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping
                                            http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping.xsd"
>
    <document name="App\Core\Onboarding\Domain\Entity\TariffPlan" db="app" collection="tariff_plans">
        <id field-name="ulid" type="ulid" strategy="NONE" />

        <field field-name="code" type="string" />
        <field field-name="name" type="string" />
        <field field-name="description" type="string" />
        <field field-name="deploymentOptions" type="collection" />
        <field field-name="functionalLimitations" type="boolean" />
        <field field-name="userLimit" type="int" nullable="true" />
        <field field-name="priceCents" type="int" />
        <field field-name="priceCurrency" type="string" />
        <field field-name="pricePeriod" type="string" />
        <field field-name="position" type="int" />
        <field field-name="enabled" type="boolean" />

        <indexes>
            <index unique="true">
                <key name="code" order="asc" />
            </index>
            <index>
                <key name="position" order="asc" />
                <key name="ulid" order="asc" />
            </index>
            <index>
                <key name="enabled" order="asc" />
                <key name="position" order="asc" />
            </index>
            <index>
                <key name="priceCents" order="asc" />
                <key name="ulid" order="asc" />
            </index>
        </indexes>
    </document>
</doctrine-mongo-mapping>
